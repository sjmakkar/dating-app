# ── Server ─────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Database (PostgreSQL + PostGIS) ────────────────────
# Local: postgres://postgres:postgres@localhost:5432/dating_app
# Supabase: use the connection string from Project Settings → Database
# NOTE: percent-encode special chars in the password. e.g. '#' -> %23, '@' -> %40.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/dating_app

# ── JWT ────────────────────────────────────────────────
# Generate strong secrets:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=replace_me_access
JWT_REFRESH_SECRET=replace_me_refresh
ACCESS_TOKEN_TTL=900            # 15 minutes (seconds)
REFRESH_TOKEN_TTL=2592000       # 30 days (seconds)

# ── Discovery defaults ─────────────────────────────────
DISCOVERY_RADIUS_KM=50
DISCOVERY_PAGE_SIZE=20
LAUNCH_CITY=Bengaluru

# ── Provider verification (Phase 1 stubs; fill when live) ──
# When unset, providers run in DEV mode: phone OTP is fixed, google/apple tokens are trusted as-is.
OTP_DEV_CODE=000000
# Comma-separated accepted audiences. Leave empty to run providers in DEV mode.
# Google: your OAuth *Web* client ID (what @react-native-google-signin webClientId issues tokens for).
#   Optionally add the iOS/Android client IDs too.
GOOGLE_CLIENT_IDS=
# Apple: your app's bundle identifier (e.g. com.example.datingapp). Add a Service ID too if you add web/Android later.
APPLE_CLIENT_IDS=

# ── Managed chat provider (Stream / Sendbird) ──────────
CHAT_PROVIDER=stub          # stub | stream | sendbird
CHAT_API_KEY=
CHAT_API_SECRET=

# ── SMS provider for phone OTP (Twilio / MSG91 etc.) ───
# SMS_PROVIDER: stub (dev, code 000000) | twilio
SMS_PROVIDER=stub
SMS_API_KEY=
# Twilio Verify (used when SMS_PROVIDER=twilio) — from console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# ── Photo storage (Supabase Storage, CDN-served) ───────
# When set, uploaded photos go to a Supabase Storage bucket and the CDN URL is
# stored. When empty, photos fall back to local disk (dev only).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=photos
