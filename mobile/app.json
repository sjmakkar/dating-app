{
  "expo": {
    "name": "Dating App",
    "slug": "dating-app",
    "scheme": "datingapp",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "owner": "sjmakkar",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#FF4458"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.example.datingapp",
      "usesAppleSignIn": true
    },
    "android": {
      "package": "com.example.datingapp",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "We use your location to show people near you and your distance to them."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "We access your photos so you can add them to your profile."
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.REPLACE_WITH_IOS_CLIENT_ID"
        }
      ],
      "expo-apple-authentication",
      "expo-notifications"
    ],
    "extra": {
      "apiUrl": "http://localhost:4000",
      "eas": {
        "projectId": "5f4eaa6c-ce7d-4d13-a21a-3fd044708a20"
      }
    }
  }
}
