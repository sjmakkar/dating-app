# Public env vars are inlined at build time by Expo (must be prefixed EXPO_PUBLIC_).
# Device/emulator cannot reach "localhost" of your dev machine — use your LAN IP,
# e.g. http://192.168.1.20:4000. Android emulator can use http://10.0.2.2:4000.
EXPO_PUBLIC_API_URL=http://192.168.1.20:4000

# Google Sign-In (from Google Cloud Console → Credentials).
# WEB client ID is required: the returned idToken's audience = this value,
# which the backend verifies. iOS client ID is optional (only for iOS builds).
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=268495615387-bas7135treguug3m5j2f1a6pfcrgf5ve.apps.googleusercontent.com
